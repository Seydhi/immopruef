# ─── Frontend (Vite) ───
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_APP_URL=http://localhost:5173
VITE_USE_MOCKS=true

# ─── Supabase Edge Functions (set via: supabase secrets set KEY=VALUE) ───
# SUPABASE_URL              (auto-injected by Supabase)
# SUPABASE_SERVICE_ROLE_KEY (auto-injected by Supabase)
# SB_SERVICE_ROLE_KEY       (OPTIONAL alias — Supabase blockiert Secrets mit SUPABASE_-Prefix.
#                            Der Code nutzt SB_SERVICE_ROLE_KEY mit Fallback auf das
#                            auto-injizierte SUPABASE_SERVICE_ROLE_KEY. Nur setzen, falls
#                            der Service-Role-Key bewusst überschrieben werden soll.)
# ANTHROPIC_API_KEY=sk-ant-...
# ─── Scraper/Reader (OPTIONAL, aber empfohlen für ImmoScout24/Immowelt) ───
# BRIGHTDATA_API_TOKEN=...   (Web Unlocker — primärer Scraper für bot-geschützte Portale)
# BRIGHTDATA_ZONE=...
# JINA_API_KEY=...           (Fallback-Reader r.jina.ai)
# SCRAPER_URL=...            (optionaler Playwright-Scraper-Service)
# SCRAPER_API_KEY=...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_SINGLE=price_...
# STRIPE_PRICE_DOUBLE=price_...
# STRIPE_PRICE_TRIPLE=price_...
# STRIPE_PRICE_PREMIUM=price_...
# RESEND_API_KEY=re_...
# APP_URL=https://immopruef.de
# EMAIL_FROM=noreply@immopruef.de
