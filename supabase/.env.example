# ─── Supabase Edge Function Secrets ───
# Set via: supabase secrets set KEY=VALUE

# Service-Role-Key: SUPABASE_SERVICE_ROLE_KEY wird von Supabase automatisch injiziert.
# Der Code liest SB_SERVICE_ROLE_KEY mit Fallback auf SUPABASE_SERVICE_ROLE_KEY —
# es muss also normalerweise NICHTS gesetzt werden. SB_SERVICE_ROLE_KEY nur bei
# bewusstem Override setzen (SUPABASE_-Prefix ist für eigene Secrets gesperrt).
# SB_SERVICE_ROLE_KEY=eyJ...

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxx

# Scraper/Reader (OPTIONAL, empfohlen für ImmoScout24/Immowelt)
# BRIGHTDATA_API_TOKEN=...
# BRIGHTDATA_ZONE=...
# JINA_API_KEY=...
# SCRAPER_URL=...
# SCRAPER_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SINGLE=price_xxx
STRIPE_PRICE_DOUBLE=price_xxx
STRIPE_PRICE_TRIPLE=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@immopruef.de

# App
APP_URL=https://immopruef.de
